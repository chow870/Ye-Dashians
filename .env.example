# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# --- Frontend (Vite, must be prefixed with VITE_) ---
VITE_REACT_APP_GOOGLE_MAPS_API=your_google_maps_browser_key
VITE_BACKEND_URL=http://localhost:8000

# --- Backend ---
GOOGLE_MAPS_API=your_google_maps_server_key
PORT=8000
DB_LINK=your_mongodb_connection_string
FRONTEND_URL=http://localhost:5173

# Secret used to sign JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_long_random_secret

# Razorpay credentials
RAZORPAY_ID_KEY=your_razorpay_key_id
RAZORPAY_SECRET_KEY=your_razorpay_key_secret

# SMTP / email credentials (Gmail app password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password

# WeatherAPI (air-quality / forecast) key from weatherapi.com
WEATHER_API_KEY=your_weatherapi_key
